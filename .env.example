# Copy this file to .env and fill in your values.
# NEVER commit .env — it is listed in .gitignore.

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Embedding provider ────────────────────────────────────────────────────────
# "fastembed" (default) runs locally via ONNX — no API key needed, 100% free.
# "voyage"   requires VOYAGE_API_KEY  (paid after free tier)
# "openai"   requires OPENAI_API_KEY  (paid)
EMBEDDING_PROVIDER=voyage

# Optional: override the fastembed model (default is BAAI/bge-small-en-v1.5)
# FASTEMBED_MODEL=BAAI/bge-small-en-v1.5

# Uncomment only if using a paid provider:
# VOYAGE_API_KEY=your_voyage_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# ── Optional tunables (defaults shown) ───────────────────────────────────────
# TOP_K=5            # number of chunks retrieved per query
# CHUNK_SIZE=3500    # characters per chunk (~875 tokens)
# CHUNK_OVERLAP=350  # overlap between chunks (~88 tokens)
# MAX_UPLOAD_MB=15   # maximum upload file size
# MAX_PAGES=150      # maximum pages per uploaded PDF
