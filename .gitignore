# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Secrets — NEVER commit ────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Base PDFs — build the index locally, then commit app/index/ instead ───────
data/*.pdf

# NOTE: app/index/ is intentionally NOT gitignored.
# The pre-built FAISS artifacts (base.index, base_metadata.json) must be
# committed so they ship in the Heroku slug and are available at startup.
